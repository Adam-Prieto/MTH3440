Cell["\<\
In both of the above examples, we can clearly see the sinusoidal behavior \
that we were expecting from our solution, and also enough of a difference to \
be reflective of the additional variable. \
\>", "Text",
 CellChangeTimes->{{3.856307999193932*^9, 3.856308077471356*^9}, {
  3.8563082191168127`*^9, 
  3.856308240047082*^9}},ExpressionUUID->"87aace9b-4d46-4507-9643-\
6349862736ee"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "b.) u(x,y,0) = Sin[\[Pi]*x]*Sin[y], ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["u", "t"], "(", 
     RowBox[{"x", ",", "y", ",", "0"}], ")"}], "=", 
    RowBox[{"Sin", "[", 
     RowBox[{"\[Pi]", "*", "x"}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "7c6d2b5f-497a-4ead-87b3-2a207379cc75"],
 ", c = 1, a = 1, b = \[Pi]"
}], "Section",
 CellChangeTimes->{{3.85597278927499*^9, 3.855972794722417*^9}, {
  3.855972867243104*^9, 
  3.855972902020586*^9}},ExpressionUUID->"562cc8e9-0bed-4ccf-8757-\
8c0c9760c91d"],

Cell["\<\
To solve this particular equation, I needed to use both previous techniques \
for multiple variables as well as techniques for coefficients of multiple \
variables. Additional tactics aside, this wasn\[CloseCurlyQuote]t too bad \
despite the additional computation. \
\>", "Text",
 CellChangeTimes->{{3.856307487629137*^9, 3.8563075269096518`*^9}, {
  3.856307576331439*^9, 
  3.856307613411961*^9}},ExpressionUUID->"71888fa7-26fa-4221-8465-\
89fbe251323f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rick", "=", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "6"], "[", 
     RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", "*", "x"}], "]"}], "*", 
     RowBox[{"Sin", "[", "y", "]"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{
         SqrtBox[
          RowBox[{
           SuperscriptBox["\[Pi]", "2"], "+", "1"}]], "*", "t"}], "]"}], "+", 
       
       FractionBox[
        RowBox[{"Sin", "[", 
         RowBox[{
          SqrtBox[
           RowBox[{
            SuperscriptBox["\[Pi]", "2"], "+", "1"}]], "t"}], "]"}], 
        SqrtBox[
         RowBox[{
          SuperscriptBox["\[Pi]", "2"], "+", "1"}]]]}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Hailey", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "61"], "[", 
     RowBox[{"x_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", "*", "x"}], "]"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{
         SqrtBox[
          RowBox[{
           SuperscriptBox["\[Pi]", "2"], "+", "1"}]], "*", "t"}], "]"}], "+", 
       
       FractionBox[
        RowBox[{"Sin", "[", 
         RowBox[{
