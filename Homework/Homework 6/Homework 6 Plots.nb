Cell[CellGroupData[{

Cell["b.) u(0,t) = 1, u(\[Pi],t) = 0, f(x) = 1 - x, k = 1, and L = \[Pi]", \
"Section",
 CellChangeTimes->{{3.855972370328355*^9, 
  3.855972408161949*^9}},ExpressionUUID->"f282aa19-58a3-4575-959b-\
01aa745c8b54"],

Cell[TextData[{
 "For this problem, I obtained the general solution \[LongDash] u(x,t) = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"-", "x"}], "\[Pi]"], TraditionalForm]],ExpressionUUID->
  "078a9f01-2a25-42f1-9598-2fd3db202c55"],
 " + 1 + ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"n", "=", "1"}], "\[Infinity]"], 
    RowBox[{
     FractionBox[
      RowBox[{"2", "-", "\[Pi]"}], 
      RowBox[{"\[Pi]", "*", "n"}]], "*", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["n", "2"]}], "*", "t"}]], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"n", "*", "x"}], "]"}]}]}], TraditionalForm]],ExpressionUUID->
  "27d47f6f-7b50-4514-ba76-5f04f849032a"],
 " \[LongDash] by adding the particular linear equation to the fourier sine \
series.  For simplicity sake, I will only evaluate a few terms of the series \
and plot the result here. "
}], "Text",
 CellChangeTimes->{{3.8559729656367083`*^9, 3.8559732824170837`*^9}, {
  3.8559734195836487`*^9, 3.855973456137046*^9}, {3.855973508369927*^9, 
  3.8559735114256*^9}, {3.855973802248543*^9, 3.855973840827442*^9}, {
  3.855974716356702*^9, 
  3.855974716939918*^9}},ExpressionUUID->"097347ae-a080-440f-bafb-\
180c755a18d0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Leah", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "2"], "[", 
     RowBox[{"x_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     FormBox[
      FractionBox[
       RowBox[{"-", "x"}], "\[Pi]"],
      TraditionalForm], " ", "+", " ", "1", " ", "+", " ", 
     RowBox[{
      FractionBox[
       RowBox[{"2", "-", "\[Pi]"}], "\[Pi]"], "*", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", "t"}]], "*", 
      RowBox[{"Sin", "[", "x", "]"}]}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "-", "\[Pi]"}], ")"}], "*", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "4"}], "t"}]]}], 
       RowBox[{"2", "*", "\[Pi]"}]], 
      RowBox[{"Sin", "[", 
       RowBox[{"2", "x"}], "]"}]}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "-", "\[Pi]"}], ")"}], "*", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "9"}], "t"}]]}], 
       RowBox[{"3", "*", "\[Pi]"}]], 
      RowBox[{"Sin", "[", 
       RowBox[{"3", "x"}], "]"}]}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "-", "\[Pi]"}], ")"}], "*", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "16"}], "t"}]]}], 
       RowBox[{"4", "*", "\[Pi]"}]], 
      RowBox[{"Sin", "[", 
       RowBox[{"4", "x"}], "]"}]}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "-", "\[Pi]"}], ")"}], "*", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "25"}], "t"}]]}], 
       RowBox[{"5", "*", "\[Pi]"}]], 
      RowBox[{"Sin", "[", 
       RowBox[{"5", "x"}], "]"}]}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.855973308331094*^9, 3.855973343367437*^9}, {
  3.855973469982291*^9, 3.855973532487184*^9}, {3.855973617037675*^9, 
  3.85597364807236*^9}, {3.855973678514244*^9, 3.855973720681527*^9}, {
  3.855973845891467*^9, 3.8559738722650337`*^9}, {3.85597472703508*^9, 
  3.8559747355850353`*^9}, {3.855975014711235*^9, 3.855975019378583*^9}, {
  3.8559751674382477`*^9, 3.855975173938305*^9}, {3.855975204720931*^9, 
  3.855975212165617*^9}, {3.856060716162475*^9, 3.85606073068668*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"95979180-04cf-4a54-b042-893f7cc23f08"],

