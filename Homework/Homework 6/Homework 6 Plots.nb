Cell["\<\
Again, we get two sinusoidal pictures that are consistent with our solution. \
However, this example has two solutions that are even more unique than in \
part a. \
\>", "Text",
 CellChangeTimes->{{3.856308259777926*^9, 
  3.856308345239459*^9}},ExpressionUUID->"c950be29-8a5b-4a36-9f41-\
0e25af6c5ca5"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "c.) u(x,y,0) = 0, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["u", "t"], "(", 
     RowBox[{"x", ",", "y", ",", "0"}], ")"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"e5d26589-14e7-4808-9de0-04ca8f6fccf3"],
 ", c = 3, a = b = 1"
}], "Section",
 CellChangeTimes->{{3.855972800135747*^9, 3.855972801791754*^9}, {
  3.8559729130989857`*^9, 
  3.855972935742687*^9}},ExpressionUUID->"ab188c3f-ce45-4d58-a99b-\
f918ff89e710"],

Cell["\<\
I couldn\[CloseCurlyQuote]t think of anything to say here, so let\
\[CloseCurlyQuote]s just get straight to the graphs. \
\>", "Text",
 CellChangeTimes->{{3.856308358815916*^9, 
  3.856308379310443*^9}},ExpressionUUID->"25076bbd-fb5f-4f43-8cb7-\
694594e7b7cf"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Chad", "=", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "7"], "[", 
     RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], "=", " ", 
    RowBox[{
     RowBox[{"(", 
      FractionBox["48", 
       SuperscriptBox["\[Pi]", "2"]], ")"}], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", "*", "x"}], "]"}], "*", 
     RowBox[{"Sin", "[", "y", "]"}], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"3", "*", "\[Pi]", "*", 
       SqrtBox["2"], "t"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AB", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "71"], "[", 
     RowBox[{"x_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"(", 
      FractionBox["48", 
       SuperscriptBox["\[Pi]", "2"]], ")"}], 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", "*", "x"}], "]"}], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"3", "*", "\[Pi]", "*", 
       SqrtBox["2"], "t"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Lindsey", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "72"], "[", 
     RowBox[{"y_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"(", 
      FractionBox["48", 
       SuperscriptBox["\[Pi]", "2"]], ")"}], 
     RowBox[{"Sin", "[", "y", "]"}], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"3", "*", "\[Pi]", "*", 
       SqrtBox["2"], "t"}], "]"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.856300813839157*^9, 3.856300869854073*^9}, {
  3.85630091426118*^9, 3.856301012944293*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"93bb5162-e86d-4744-979f-c34ed9688425"],

