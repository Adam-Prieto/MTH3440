Cell["\<\
A 3d sinusoid. Nothing too special here, but it does confirm my original \
expectation that the wave equation would produce a function at least a \
vaguely resembling a wave, but I digress. It\[CloseCurlyQuote]s interesting \
to note that, however that, depending on the initial conditions, we can get \
any number of \[OpenCurlyDoubleQuote]waves\[CloseCurlyDoubleQuote] for our \
solution. \
\>", "Text",
 CellChangeTimes->{{3.858725830858494*^9, 3.8587258405590277`*^9}, {
  3.858725878223672*^9, 
  3.858726011187398*^9}},ExpressionUUID->"1a34c67f-bf87-413b-bf09-\
7a1d4961ee4d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "b.) f(x,y) = 0, u(0,y) = u(1,y) = 0, u(x,0)+ ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["u", "y"], "(", 
     RowBox[{"x", ",", "0"}], ")"}], "=", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "3d0178d0-b866-441a-85bf-0748604f7746"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["u", "y"], "(", 
     RowBox[{"x", ",", "\[Pi]"}], ")"}], "=", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "79f93083-bd2a-40f4-bc7d-b5164d5f04c8"],
 "."
}], "Section",
 CellChangeTimes->{{3.858277370838298*^9, 
  3.858277433442727*^9}},ExpressionUUID->"62c5c756-efcb-4974-8331-\
e728c3563090"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"u310b", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"m", "*", "\[Pi]", "*", 
       RowBox[{"Tanh", "[", 
        RowBox[{"m", "*", 
         SuperscriptBox["\[Pi]", "2"]}], "]"}], "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"m", "*", "\[Pi]", "*", "x"}], "]"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Sinh", "[", 
          RowBox[{"m", "*", "\[Pi]", "*", "y"}], "]"}], "-", 
         RowBox[{"m", "*", "\[Pi]", "*", 
          RowBox[{"Cosh", "[", 
           RowBox[{"m", "*", "\[Pi]", "*", "y"}], "]"}]}]}], ")"}]}], ")"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"m", ",", "1", ",", "20"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.8587242256245403`*^9, 3.858724316555563*^9}, {
  3.858724360318124*^9, 3.85872440456684*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"7a23bd9a-812c-477f-877d-a969bf3f8301"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{"u310b", "[", 
    RowBox[{"x", ",", "y"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", ".25"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", ".1"}], "}"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"PlotLabel", "\[Rule]", "\"\<u310b\>\""}]}], "]"}]], "Input",
 CellChangeTimes->{{3.85872434794053*^9, 3.858724369760482*^9}, 
   3.858725644353466*^9, {3.858726034749799*^9, 3.858726042660816*^9}, {
