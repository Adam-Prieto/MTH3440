}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "c.) f(x,y) = x, u(0,y) = u(\[Pi],y) = 0, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["u", "y"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "48868c18-9184-4928-998d-1bc48ce05e6b"],
 "(x,0) = 0, + ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["u", "y"], "(", 
      RowBox[{"x", ",", "1"}], ")"}], "-", 
     RowBox[{"u", "(", 
      RowBox[{"x", ",", "1"}], ")"}]}], "=", "1"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "d3236ba0-6fe7-4a7d-963a-e2d16fe70fda"],
 "."
}], "Section",
 CellChangeTimes->{{3.858277444877489*^9, 
  3.858277526064703*^9}},ExpressionUUID->"763bdcf5-5572-4750-9429-\
a1a52c96c6a7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"u310c", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"-", "2"}], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "m"], "-", "1"}], ")"}]}], 
       RowBox[{"m", "*", "\[Pi]", "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"m", "*", 
           RowBox[{"Sinh", "[", "m", "]"}]}], "-", 
          RowBox[{"Cosh", "[", "m", "]"}]}], ")"}]}]], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"m", "*", "x"}], "]"}], "*", 
      RowBox[{"Cosh", "[", 
       RowBox[{"m", "*", "y"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"m", ",", "1", ",", "20"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.858724465712316*^9, 3.858724619788251*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"688d81af-dba1-4e30-bf8a-479f5e725950"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{"u310c", "[", 
    RowBox[{"x", ",", "y"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "25"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"PlotLabel", "\[Rule]", "\"\<u310c\>\""}]}], "]"}]], "Input",
