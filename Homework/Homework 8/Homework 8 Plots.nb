   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], "2"], "*", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", "x"}]]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "\[Infinity]"}], "}"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "2"}], " ", "-", " ", 
         RowBox[{"4", " ", "x"}], " ", "+", " ", "2"}], ")"}]}], ")"}], "2"], 
    "*", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", "x"}]]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "\[Infinity]"}], "}"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", "6"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["x", "3"]}], "+", 
         RowBox[{"9", 
          SuperscriptBox["x", "2"]}], "-", 
         RowBox[{"18", "x"}], "+", "6"}], ")"}]}], ")"}], "2"], "*", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", "x"}]]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "\[Infinity]"}], "}"}]}], "]"}]}], "Input",
