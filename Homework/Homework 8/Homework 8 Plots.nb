Cell["\<\
This solution seems to be the typical wave equation that \
we\[CloseCurlyQuote]ve gotten after many solutions to the wave equation. This \
makes sense since the above equation is homogeneous and not defined in terms \
of time. That said, the above result seems to be pretty consistent with \
previous solutions. \
\>", "Text",
 CellChangeTimes->{{3.8587253232901278`*^9, 
  3.858725408636849*^9}},ExpressionUUID->"5a0602cb-6a5b-4dee-80ca-\
b8222fad7a2a"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "b.) f(x,y) = Sin[x], ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["f", "1"], "(", "x", ")"}], "=", "0"}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["f", "2"], "(", "x", ")"}], "=", "x"}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["g", "1"], "(", "y", ")"}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["g", "2"], "(", "y", ")"}], "=", "0"}]}], ",", " ", 
    RowBox[{"a", "=", "1"}], ",", 
    RowBox[{"b", "=", "\[Pi]"}]}], TraditionalForm]],ExpressionUUID->
  "044341f9-3445-4cee-82b2-9865d2a1a386"],
 "."
}], "Section",
 CellChangeTimes->{{3.85827716304156*^9, 
  3.8582772010484943`*^9}},ExpressionUUID->"f00194f6-8167-48e4-9e03-\
17fbb4010832"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"n", "=", "1"}], "\[Infinity]"], 
    RowBox[{"2", 
     FractionBox[
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{"n", "+", "1"}]], 
      RowBox[{"n", "*", "\[Pi]", "*", 
       RowBox[{"Sinh", "[", 
        RowBox[{"n", "*", 
         SuperscriptBox["\[Pi]", "2"]}], "]"}]}]], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"n", "*", "\[Pi]", "*", "x"}], "]"}], "*", 
     RowBox[{"Sinh", "[", 
      RowBox[{"n", "*", "\[Pi]", "*", "y"}], "]"}]}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "70c1f03d-a4d6-47c7-997f-f1e7d37c219d"],
 " + ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"n", "=", "1"}], "\[Infinity]"], 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"m", "=", "1"}], "\[Infinity]"], 
     RowBox[{
      FractionBox["4", 
       RowBox[{
        RowBox[{"\[Pi]", "(", 
         RowBox[{
          RowBox[{"2", "n"}], "-", "1"}], ")"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["m", "2"], "*", 
           SuperscriptBox["\[Pi]", "2"]}], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "n"}], "-", "1"}], ")"}], "2"]}], ")"}]}]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         FractionBox["1", 
          RowBox[{
           RowBox[{"m", "*", "\[Pi]"}], "-", "1"}]], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{
           RowBox[{"m", "*", 
            SuperscriptBox["\[Pi]", "2"]}], "-", "\[Pi]"}], "]"}]}], "-", 
        RowBox[{
         FractionBox["1", 
          RowBox[{"m\[Pi]", "+", "1"}]], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{
           RowBox[{"m", "*", 
            SuperscriptBox["\[Pi]", "2"]}], "-", "\[Pi]"}], "]"}]}]}], 
       ")"}]}]}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "34e9851d-c7c9-4d02-8ff5-fdd731bf76cf"],
 "Sin[m*\[Pi]*x]*Sin[(2n-1)y]"
}], "Text",
 CellChangeTimes->{{3.858719258743095*^9, 
  3.858719572247669*^9}},ExpressionUUID->"2830879e-1917-4828-9b07-\
22f18b062360"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"u39b", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"2", 
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"n", "+", "1"}]], 
        RowBox[{"n", "*", "\[Pi]", "*", 
         RowBox[{"Sinh", "[", 
          RowBox[{"n", "*", 
           SuperscriptBox["\[Pi]", "2"]}], "]"}]}]], "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"n", "*", "\[Pi]", "*", "x"}], "]"}], "*", 
       RowBox[{"Sinh", "[", 
        RowBox[{"n", "*", "\[Pi]", "*", "y"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "2", ",", "20"}], "}"}]}], "]"}], "+", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox["4", 
          RowBox[{
           RowBox[{"\[Pi]", "(", 
            RowBox[{
             RowBox[{"2", "n"}], "-", "1"}], ")"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              SuperscriptBox["m", "2"], "*", 
              SuperscriptBox["\[Pi]", "2"]}], "+", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", "n"}], "-", "1"}], ")"}], "2"]}], ")"}]}]], "*", 
         
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            FractionBox["1", 
             RowBox[{"\[Pi]", "-", "1"}]], "*", 
            RowBox[{"Sin", "[", 
             RowBox[{
              SuperscriptBox["\[Pi]", "2"], "-", "\[Pi]"}], "]"}]}], "-", 
           RowBox[{
            FractionBox["1", 
             RowBox[{"\[Pi]", "+", "1"}]], 
            RowBox[{"Sin", "[", 
             RowBox[{
              SuperscriptBox["\[Pi]", "2"], "-", "\[Pi]"}], "]"}]}]}], ")"}], 
         "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Pi]", "*", "x"}], "]"}], "*", 
         RowBox[{"Sin", "[", "y", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"m", ",", "2", ",", "20"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "2", ",", "10"}], "}"}]}], "]"}]}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.858719593416266*^9, 3.858719948853485*^9}, 
   3.85871997946984*^9, {3.8587203728695087`*^9, 3.858720614616284*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"9370c2ea-78e0-403d-a357-8b68335e1c01"],

