Notebook[{

Cell[CellGroupData[{
Cell["Homework 8 Plots", "Title",
 CellChangeTimes->{{3.8582625259061623`*^9, 
  3.85826253067459*^9}},ExpressionUUID->"f419a297-725f-446d-962a-\
a178d09b71c7"],

Cell["\<\
Adam Prieto and Sean DeVaney
Professor Shelley Poole
MTH 3440 - Partial Differential Equations
11 April 2022\
\>", "Text",
 CellChangeTimes->{
  3.8582625381055603`*^9, {3.858262954666641*^9, 3.8582629581756496`*^9}, {
   3.858718480650539*^9, 3.85871850767838*^9}, {3.85872006706671*^9, 
   3.85872006761903*^9}},ExpressionUUID->"2bb6b777-b9c0-4e47-a28a-\
0916d27c4367"],

Cell["3.9 Problems", "Subtitle",
 CellChangeTimes->{{3.858262560227174*^9, 
  3.858262565457081*^9}},ExpressionUUID->"dad772b0-3949-45b7-90e4-\
e153a5f63f6a"],

Cell[CellGroupData[{

Cell[TextData[{
 "2.)Plot all solutions to Poisson\[CloseCurlyQuote]s equation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["u", "xx"], "+", 
     SubscriptBox["u", "yy"]}], "=", 
    RowBox[{"f", "(", 
     RowBox[{"x", ",", "y"}], ")"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "53bc9c50-cd8a-48c5-a59c-648117d3f185"],
 " and discuss the behaviors of the solutions. Compare them with your \
solutions to Laplace\[CloseCurlyQuote]s equation. What do you notice about \
the effects of a forcing function?"
}], "Chapter",
 CellChangeTimes->{{3.8582625828394823`*^9, 
  3.858262669934268*^9}},ExpressionUUID->"6b6a9359-4ff0-4c9f-876d-\
732608f1e0f7"],

Cell[CellGroupData[{

Cell[TextData[{
 "a.) f(x,y) = x, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["f", "1"], "(", "x", ")"}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["f", "2"], "(", "x", ")"}], "=", 
      RowBox[{
       RowBox[{
        SubscriptBox["g", "1"], "(", "y", ")"}], "=", 
       RowBox[{
        RowBox[{
         SubscriptBox["g", "2"], "(", "y", ")"}], "=", "0"}]}]}]}], ",", " ", 
    
    RowBox[{"a", "=", 
     RowBox[{"b", "=", "1"}]}]}], TraditionalForm]],ExpressionUUID->
  "95ee10ed-3b65-4fed-acd2-ab0a2452793e"],
 "."
}], "Section",
 CellChangeTimes->{{3.858277053881997*^9, 
  3.858277160650062*^9}},ExpressionUUID->"2b8f2a7a-e725-44ac-9e0d-\
e06a80a37a0d"],

Cell[TextData[{
 "For this problem, we obtained the double sum ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"n", "=", "1"}], "\[Infinity]"], 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"m", "=", "1"}], "\[Infinity]"], 
     RowBox[{
      FractionBox[
       RowBox[{"8", "*", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"m", "+", "1"}]]}], 
       RowBox[{
        RowBox[{"m", "(", 
         RowBox[{
          RowBox[{"2", "n"}], "-", "1"}], ")"}], 
        RowBox[{
         SuperscriptBox["\[Pi]", "4"], "(", 
         RowBox[{
          SuperscriptBox["m", "2"], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "n"}], "-", "1"}], ")"}], "2"]}], ")"}]}]], "*", 
      RowBox[{"Sin", "[", "m\[Pi]x", "]"}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "n"}], "-", "1"}], ")"}], "\[Pi]y"}], "]"}]}]}]}], 
   TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "29effbbf-8ac5-4c5a-9036-3f13d3537ac5"],
 ". The first few terms of this series are ",
 Cell[BoxData[
  FormBox[
   FractionBox["8", 
    RowBox[{"1", "*", "1", "*", 
     RowBox[{
      SuperscriptBox["\[Pi]", "4"], "(", 
      RowBox[{"1", "+", 
       SuperscriptBox[
        RowBox[{"(", "1", ")"}], "2"]}], ")"}]}]], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "8bde9318-4df8-43cf-92b6-774b4a96658b"],
 "Sin[\[Pi] * x] Sin[\[Pi] * y] - ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["8", 
     RowBox[{"2", 
      RowBox[{"(", "3", ")"}], 
      RowBox[{
       SuperscriptBox["\[Pi]", "4"], "(", 
       RowBox[{"4", "+", 
        SuperscriptBox[
         RowBox[{"(", "3", ")"}], "2"]}], ")"}]}]], 
    RowBox[{"Sin", "[", 
     RowBox[{"2", "\[Pi]", "*", "x"}], "]"}], 
    RowBox[{"Sin", "[", 
     RowBox[{"3", "\[Pi]y"}], "]"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "2cc6eef4-62ec-4c36-a1f4-64e0886b4271"],
 " + ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["8", 
     RowBox[{"3", 
      RowBox[{"(", "5", ")"}], 
      RowBox[{
       SuperscriptBox["\[Pi]", "4"], "(", 
       RowBox[{"9", "+", 
        SuperscriptBox[
         RowBox[{"(", "5", ")"}], "2"]}], ")"}]}]], 
    RowBox[{"Sin", "[", 
     RowBox[{"3", "\[Pi]x"}], "]"}], 
    RowBox[{"Sin", "[", 
     RowBox[{"5", "\[Pi]y"}], "]"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "cfa198f1-0b8c-40b6-9160-fea772da804a"],
 "+... Let\[CloseCurlyQuote]s graph that out."
}], "Text",
 CellChangeTimes->{{3.858718465897105*^9, 3.8587184758468924`*^9}, {
  3.858718511981889*^9, 
  3.858718997891841*^9}},ExpressionUUID->"cef2b907-c178-4b17-8a79-\
d5b681f57c9f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"u39a", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"4", 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", "*", "x"}], "]"}], 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", "*", "y"}], "]"}]}], "-", 
    RowBox[{
     FractionBox["8", 
      RowBox[{"6", "*", 
       SuperscriptBox["\[Pi]", "4"], "*", "13"}]], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"2", "\[Pi]", "*", "x"}], "]"}], 
     RowBox[{"Sin", "[", 
      RowBox[{"3", "\[Pi]", "*", "y"}], "]"}]}], "+", 
    RowBox[{
     FractionBox["8", 
      RowBox[{"15", 
       SuperscriptBox["\[Pi]", "4"], "*", "34"}]], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"3", "\[Pi]", "*", "x"}], "]"}], 
     RowBox[{"Sin", "[", 
      RowBox[{"5", "\[Pi]", "*", "y"}], "]"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.8587190053066196`*^9, 3.858719183478788*^9}, {
  3.8587206516675053`*^9, 3.858720682419805*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"1e268437-0145-4344-b99c-869ea065dc9a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{"u39a", "[", 
    RowBox[{"x", ",", "y"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "Pi"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"PlotLabel", "\[Rule]", "\"\<u39a\>\""}]}], "]"}]], "Input",
 CellChangeTimes->{{3.858719219705388*^9, 3.858719224318798*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"0466798b-b37d-4502-ba22-8826e6e9898d"],

