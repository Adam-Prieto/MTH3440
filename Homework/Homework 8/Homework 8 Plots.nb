Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"u39c", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"2", 
       FractionBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", "\[Pi]"}], ")"}], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"-", "1"}], ")"}], 
            RowBox[{"m", "+", "1"}]]}]}], ")"}], 
        RowBox[{"m", "*", "\[Pi]", "*", 
         RowBox[{"Sinh", "[", 
          RowBox[{"2", "m"}], "]"}]}]], "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"m", "*", "x"}], "]"}], "*", 
       RowBox[{"Sinh", "[", 
        RowBox[{"m", "*", "y"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"m", ",", "1", ",", "2"}], "}"}]}], "]"}], "+", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"4", 
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"n", "+", "1"}]], 
        RowBox[{"n", "*", "\[Pi]", "*", 
         RowBox[{"Sinh", "[", 
          RowBox[{"n", "*", 
           FractionBox[
            SuperscriptBox["\[Pi]", "2"], "2"]}], "]"}]}]], "*", 
       RowBox[{"Sinh", "[", 
        RowBox[{"n", "*", "\[Pi]", "*", "x"}], "]"}], "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"n", "*", "\[Pi]", "*", "y"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", "2"}], "}"}]}], "]"}], "+", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox["32", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "m"}], "-", "1"}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "n"}], "-", "1"}], ")"}]}]], "*", 
         FractionBox["1", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", "m"}], "-", "1"}], ")"}], "2"], "*", 
           SuperscriptBox["\[Pi]", "2"], "*", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", "n"}], "-", "1"}], ")"}], "2"], "*", 
           FractionBox[
            SuperscriptBox["\[Pi]", "4"], "4"]}]], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "m"}], "-", "1"}], ")"}], "x"}], "]"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "n"}], "-", "1"}], ")"}], "\[Pi]", "*", 
           FractionBox["y", "2"]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"m", ",", "1", ",", "2"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", "2"}], "}"}]}], "]"}]}]}], ";"}]], "Input",\

