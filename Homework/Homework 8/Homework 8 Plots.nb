Cell["\<\
This solution is interesting. For starters, it seems to behave using the \
typical wave equation phenomena we\[CloseCurlyQuote]ve seen before. However, \
we also seem to generate behavior reminiscent of the heat equation by the \
large pillars towards the front of the graph. That said, this seems to be a \
fairly interesting result and one that we should add to our knowledge base of \
general solutions. \
\>", "Text",
 CellChangeTimes->{{3.858725414123901*^9, 
  3.8587255467118177`*^9}},ExpressionUUID->"5ac8f34d-feca-4ae4-92b0-\
245a2c0fd741"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "c.) f(x,y) = 2, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["f", "1"], "(", "x", ")"}], "=", "0"}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["f", "2"], "(", "x", ")"}], "=", 
     RowBox[{"1", "-", "x"}]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["g", "1"], "(", "y", ")"}], "=", "0"}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["g", "2"], "(", "y", ")"}], "=", "y"}], ",", " ", 
    RowBox[{"a", "=", "\[Pi]"}], ",", 
