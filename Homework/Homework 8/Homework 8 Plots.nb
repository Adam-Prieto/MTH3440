Cell[TextData[{
 "Calculate the square of the functions i.e ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["1", "2"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "6b976468-a550-4cf6-ab51-8d16215cf7b3"],
 ", ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
