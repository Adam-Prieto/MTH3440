       SuperscriptBox["x", "2"]}], "-", "1"}], ")"}], "*", 
    FractionBox["1", "2"], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"5", 
       SuperscriptBox["x", "3"]}], "-", 
      RowBox[{"3", "x"}]}], ")"}], "*", "1"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Norm3", " ", "=", " ", 
  SqrtBox[
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         FractionBox["1", "2"], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"3", 
            SuperscriptBox["x", "2"]}], "-", "1"}], ")"}]}], ")"}], "2"], "*",
       "1"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]]}]}], "Input",
 CellChangeTimes->{
  3.858727518051365*^9, {3.8587277799659*^9, 3.858727793290884*^9}},
 CellLabel->"In[72]:=",ExpressionUUID->"1543087a-1b56-4c31-ac31-97a456c568d3"],

