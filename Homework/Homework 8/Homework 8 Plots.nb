Cell["\<\
Since all of the above norms are not equal to 1, they are just orthogonal and \
not orthonormal. \
\>", "Text",
 CellChangeTimes->{{3.858727883213022*^9, 
  3.858727908780357*^9}},ExpressionUUID->"57c85936-0ece-413f-9374-\
13a5ba1b3ece"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "b.) The Laguerre Polynomials: 1, 1-x, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"1", "/", "2"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "^", "2"}], " ", "-", " ", 
       RowBox[{"4", " ", "x"}], " ", "+", " ", "2"}], ")"}]}], ","}], 
   TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "fa03c193-66e5-49f2-8314-70b1c6042e80"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["1", "6"], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["x", "3"]}], "+", 
      RowBox[{"9", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"18", "x"}], "+", "6"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"305ac1d5-74f8-4cd4-859d-b747d766dd00"],
 " on [0, \[Infinity]) with weight function w(x) = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", "x"}]], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "87c8a42a-21e8-4cbf-8eae-2a28e19bd7b9"]
}], "Section",
 CellChangeTimes->{{3.8587279246346483`*^9, 3.8587280309186783`*^9}, {
  3.858728239470437*^9, 
  3.858728262813963*^9}},ExpressionUUID->"cf18bd54-c3f5-4e50-812f-\
0df093cfeefe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "We", " ", "already", " ", "found", " ", "the", " ", "norm", " ", "for", 
     " ", "1", " ", "above"}], ";", " ", 
    RowBox[{"the", " ", "answer", " ", "was", " ", 
     RowBox[{
      SqrtBox["2"], "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Norm5", " ", "=", " ", 
    SqrtBox[
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", "x"}], ")"}], "2"], "*", "1"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]]}], 
   "\[IndentingNewLine]", 
   RowBox[{"Norm6", " ", "=", " ", 
    SqrtBox[
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           FractionBox["1", "2"], 
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox["x", "2"], "-", 
             RowBox[{"4", "x"}], "+", "2"}], ")"}]}], ")"}], "2"], "*", "1"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]]}], 
   "\[IndentingNewLine]", 
   RowBox[{"Norm7", "=", " ", 
    SqrtBox[
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          FormBox[
           RowBox[{
            FractionBox["1", "6"], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", 
               SuperscriptBox["x", "3"]}], "+", 
              RowBox[{"9", 
               SuperscriptBox["x", "2"]}], "-", 
              RowBox[{"18", "x"}], "+", "6"}], ")"}]}],
           TraditionalForm], ")"}], "2"], "*", "1"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]]}]}]}]], "Input",
 CellChangeTimes->{{3.8587280417786903`*^9, 3.858728156335338*^9}},
 CellLabel->"In[80]:=",ExpressionUUID->"1d544d19-7f65-4a6b-aa4f-6971382e0b17"],

