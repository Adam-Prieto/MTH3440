Cell["\<\
Another sinusoid. However, this graph has sharper inclines as x increases, \
likely a result of the two sine terms in our Fourier Series solution. With \
that said, we can begin to understand what happens when we start varying our \
solutions. For example, the previous solution had peaks that rose even faster \
than in this problem, but the current solution has wider bases. This is due \
to the initial conditions of the problem, and is a great way of showing how \
final solutions can be dependant on the initial conditions. \
\>", "Text",
 CellChangeTimes->{{3.858092928407926*^9, 3.858093003652413*^9}, {
  3.858093040982087*^9, 3.858093144179146*^9}, {3.858093193606923*^9, 
  3.85809329909868*^9}},ExpressionUUID->"ca52d44c-91d5-4c32-b93b-\
658094d9941c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "c.) a = 1, b = 2, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["f", "1"], "(", "x", ")"}], " ", "=", " ", "0"}], 
   TraditionalForm]],ExpressionUUID->"4dfa9c4d-aefb-4fde-808b-bcf88439bc20"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["f", "2"], "(", "x", ")"}], " ", "=", " ", 
    RowBox[{"1", "-", "x"}]}], TraditionalForm]],ExpressionUUID->
  "8ed1b3c2-7286-48f6-8fc2-a8ed3e08bc62"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["g", "1"], "(", "y", ")"}], " ", "=", " ", "0"}], 
   TraditionalForm]],ExpressionUUID->"4b5ec63c-e1c7-4500-a5bc-bcf8a5cd6af8"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["g", "2"], "(", "y", ")"}], "=", "y"}], TraditionalForm]],
  ExpressionUUID->"74709faa-fb52-4055-ba08-86e01cc392c2"],
 "."
}], "Section",
 CellChangeTimes->{{3.858005434130422*^9, 3.8580054347253027`*^9}, {
  3.8580056203764467`*^9, 
  3.858005679603923*^9}},ExpressionUUID->"a79679d6-19c7-4738-a97c-\
086f972f0247"],

Cell[BoxData[
 RowBox[{
  RowBox[{"allBenWork", " ", "=", 
   RowBox[{
    RowBox[{"p3813", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"n", " ", "Pi", " ", "x"}], "]"}], " ", 
           RowBox[{"Sinh", "[", 
            RowBox[{"n", " ", "Pi", " ", "y"}], "]"}]}], ")"}], "/", "n"}], 
        " ", "Pi", " ", 
        RowBox[{"Sinh", "[", 
         RowBox[{"n", " ", "Pi"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "10"}], "}"}]}], "]"}], "+", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "8"}], " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"-", "1"}], ")"}], "^", "n"}]}], ")"}], " ", 
           RowBox[{"Sinh", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"n", " ", "Pi", " ", "x"}], ")"}], "/", "2"}], "]"}], 
           " ", 
           RowBox[{"Sin", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"n", " ", "Pi", " ", "y"}], ")"}], "/", "2"}], "]"}]}], 
          ")"}], "/", "n"}], " ", "Pi", " ", 
        RowBox[{"Sinh", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"n", " ", "Pi"}], ")"}], "/", "2"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "10"}], "}"}]}], "]"}]}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.8580224744518957`*^9, 3.858022474463999*^9}, {
  3.8580225161538477`*^9, 3.8580226036084538`*^9}},
 CellLabel->"In[23]:=",ExpressionUUID->"9610cea3-d7c2-4ebf-8fc2-4744ab5879b5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{"allBenWork", ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", "2"}], "}"}], ",", 
   RowBox[{"Mesh", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"MeshStyle", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"PlotTheme", "\[Rule]", "\"\<Marketing\>\""}], ",", 
   RowBox[{"PlotLegends", "\[Rule]", " ", "\"\<Expressions\>\""}], ",", 
   RowBox[{"PlotLabel", "\[Rule]", "\"\<allBenWork\>\""}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8580225864219418`*^9, 3.858022591709652*^9}, {
  3.858022624744831*^9, 3.858022651913381*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"fd8f7c6c-9e23-41ba-a192-c5c0d9290a2c"],

