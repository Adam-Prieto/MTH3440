Cell["3.7 Problems", "Subtitle",
 CellChangeTimes->{{3.8580050128560057`*^9, 
  3.858005015804781*^9}},ExpressionUUID->"7a7428f5-db43-419b-b2de-\
77576e85a552"],

Cell[CellGroupData[{

Cell[TextData[{
 "2.) Plot all solutions to the 2D Heat Equation: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["u", "t"], "=", 
    RowBox[{"k", "(", 
     RowBox[{
      SubscriptBox["u", "xx"], "+", 
      SubscriptBox["u", "yy"]}], ")"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "2d63e734-524c-4b5b-bec4-5ac3f0d51f03"],
 ". Evaluate the solutions and their behaviors. Discuss characteristics and \
similarities. "
}], "Chapter",
 CellChangeTimes->{{3.858005075764475*^9, 3.858005130456555*^9}, {
  3.858005811994431*^9, 
  3.8580058128750467`*^9}},ExpressionUUID->"708c5b88-426a-41a2-bae1-\
e5c1a8d6438e"],

Cell[CellGroupData[{

Cell["a.) u(x,y,0) = sin(2x)*sin(y), k = 1, a=b=\[Pi]", "Section",
 CellChangeTimes->{{3.858005248717805*^9, 3.858005259816197*^9}, {
  3.8580053010637093`*^9, 
  3.858005328385644*^9}},ExpressionUUID->"0026fc76-17fa-44ea-b9c5-\
6db9057b3127"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Adam", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "11"], "[", 
     RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "5"}], "t"}]], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"2", "x"}], "]"}], 
     RowBox[{"Sin", "[", "y", "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Brendan", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "12"], "[", 
     RowBox[{"x_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "5"}], "t"}]], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"2", "x"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Lettie", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "13"], "[", 
     RowBox[{"y_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "5"}], "t"}]], "*", 
     RowBox[{"Sin", "[", "y", "]"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.858006479827489*^9, 3.85800654766986*^9}, {
  3.858088986479354*^9, 3.858089039213366*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"622337ac-d4a8-48dd-9da2-1cfb4c6bcec8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Plot3D", "[", 
    RowBox[{
     RowBox[{
      SubscriptBox["u", "11"], "[", 
      RowBox[{"x", ",", "y", ",", "t"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
