Cell[TextData[{
 "As with example \[OpenCurlyDoubleQuote]a\[CloseCurlyDoubleQuote], I get a \
repeated, sinusoidal dispersion of heat waves over time here in example \
\[OpenCurlyDoubleQuote]b\[CloseCurlyDoubleQuote]. With the  similar solutions \
popping up again, I\[CloseCurlyQuote]m left wondering if there\
\[CloseCurlyQuote]s more similarities to these problems than what I\
\[CloseCurlyQuote]ve seen and discussed thus far. For example, do ",
 StyleBox["all ",
  FontSlant->"Italic"],
 "two dimensional heat equation solutions behave this way? If not, what might \
some other, unique functions look like when graphed out? These questions are \
gnawing at my curious side, and I hope that I\[CloseCurlyQuote]m able to get \
an answer later on in the course. "
}], "Text",
 CellChangeTimes->{{3.858092120700843*^9, 
  3.85809238975526*^9}},ExpressionUUID->"439a96d6-8349-44df-bbe4-\
c5becc5f2b66"]
}, Open  ]],

Cell[CellGroupData[{

Cell["c. u(x,y,0) = x, k = 3, a = b = 1", "Section",
 CellChangeTimes->{{3.858005255884726*^9, 3.85800525620113*^9}, {
  3.8580053929235163`*^9, 
  3.858005410504871*^9}},ExpressionUUID->"066b6041-55de-4613-90fc-\
c330f3c9794b"],

Cell[TextData[{
 "u(x,y,t) = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "+", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"m", "=", "1"}], "\[Infinity]"], 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"n", "=", "1"}], "\[Infinity]"], 
      RowBox[{
       FractionBox[
        RowBox[{"[", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "m"], "-", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], 
           RowBox[{"m", "+", "n"}]]}], "]"}], 
        RowBox[{"mn", "*", 
         SuperscriptBox["\[Pi]", "2"]}]], "*", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "3"}], 
         RowBox[{
          SuperscriptBox["\[Pi]", "2"], "(", 
          RowBox[{
           SuperscriptBox["m", "2"], "+", 
           SuperscriptBox["n", "2"]}], ")"}]}]], 
       RowBox[{"Sin", "[", "m\[Pi]x", "]"}], 
       RowBox[{"Sin", "[", "n\[Pi]y", "]"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"b6ca554c-8445-4df1-9cd4-8fd7094c0ff1"],
 "; evaluating one term gets us:\nu(x,y,t) = x + ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"-", "2"}], 
     SuperscriptBox["\[Pi]", "2"]], "*", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"6", 
      SuperscriptBox["\[Pi]", "2"], "t"}]], "*", 
    RowBox[{"Sin", "[", "\[Pi]x", "]"}], "*", 
    RowBox[{"Sin", "[", "\[Pi]y", "]"}]}], TraditionalForm]],ExpressionUUID->
  "6c3ea200-65d6-47bc-9421-b8e694fb5ce9"],
 " "
}], "Text",
 CellChangeTimes->{{3.858016120386541*^9, 3.8580164607077007`*^9}, 
   3.858089500058775*^9},ExpressionUUID->"256f2d5e-dc09-454b-8970-\
8a8c1926b2e6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Nate", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "31"], "[", 
     RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], "=", 
    RowBox[{"x", "+", 
     RowBox[{
      FractionBox[
       RowBox[{"-", "2"}], 
       SuperscriptBox["\[Pi]", "2"]], "*", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"6", 
        SuperscriptBox["\[Pi]", "2"], "*", "t"}]], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Pi]", " ", "*", " ", "x"}], "]"}], " ", "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Pi]", "*", "y"}], "]"}]}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Juliet", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "32"], "[", 
     RowBox[{"x_", ",", "t_"}], "]"}], "=", 
    RowBox[{"x", "+", 
     RowBox[{
      FractionBox[
       RowBox[{"-", "2"}], 
       SuperscriptBox["\[Pi]", "2"]], "*", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"6", 
        SuperscriptBox["\[Pi]", "2"], "*", "t"}]], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Pi]", " ", "*", " ", "x"}], "]"}]}]}]}]}], " ", 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"drRajan", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "33"], "[", 
     RowBox[{"y_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"-", "2"}], 
      SuperscriptBox["\[Pi]", "2"]], "*", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"6", 
       SuperscriptBox["\[Pi]", "2"], "*", "t"}]], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", "*", "y"}], "]"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.8580895966931133`*^9, 3.858089824774177*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"dba90668-ab5f-48ca-8bfb-8a1ba00ed73b"],

