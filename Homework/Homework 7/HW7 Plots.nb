Cell[TextData[{
 "In all of the above cases, I get answers that are similar to my previous \
answers when dealing with the one dimensional heat equation, in that I get a \
dispersion in space related to my equation. This is expected since I\
\[CloseCurlyQuote]m dealing with a dominant exponential decaying term \
\[LongDash] ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "k"}], "*", "t"}]], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "22e7d53b-461d-4ad4-9906-b6facc639aa6"],
 " \[LongDash] that dictates the behavior of my function. However, I also \
often deal with sinusoidal terms that often cause repeated hills and valleys \
in my graphs (see the above Brendan graph for a visual example). Regardless, \
it\[CloseCurlyQuote]s nice to know that the intuition that was introduced in \
one dimension holds true in higher dimensions as well.  "
}], "Text",
 CellChangeTimes->{{3.8580917013931017`*^9, 3.858091896108246*^9}, {
  3.858091971446348*^9, 
  3.858092114146041*^9}},ExpressionUUID->"48ed75d3-3013-4eee-b271-\
f7523803fafc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["b.) u(x,y,0) = sin(\[Pi] x)*sin(y), k = 4, a = 1, b = \[Pi]", "Section",
 CellChangeTimes->{{3.858005253084381*^9, 3.858005253728526*^9}, {
  3.858005342846785*^9, 3.8580053898013783`*^9}, {3.8580085057140636`*^9, 
  3.858008508101873*^9}},ExpressionUUID->"99477b42-496b-44bd-ab63-\
3021083098f9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Sean", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "21"], "[", 
     RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], "=", " ", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "4"}], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["\[Pi]", "2"], "+", "1"}], ")"}], "*", "t"}]], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", "*", "x"}], "]"}], "*", 
     RowBox[{"Sin", "[", "y", "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Alana", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "22"], "[", 
     RowBox[{"x_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "4"}], 
       RowBox[{"(", 
        RowBox[{
