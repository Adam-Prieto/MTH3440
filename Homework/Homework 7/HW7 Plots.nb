Cell["\<\
Our first solution to Laplace\[CloseCurlyQuote]s equation is a familiar \
sinusoidal relationship that we\[CloseCurlyQuote]ve seen countless times \
already (even in this very problem set). I guess I shouldn\[CloseCurlyQuote]t \
be too surprised since a fourier series is used to approximate the true \
solution\[CloseCurlyQuote]s shape, but it\[CloseCurlyQuote]s nice to work \
with similar results nonetheless.  \
\>", "Text",
 CellChangeTimes->{{3.85809277354828*^9, 
  3.858092915428919*^9}},ExpressionUUID->"99db5bdf-cb85-4d36-ae85-\
6007ff60087b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "b.) a = b = 1, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["g", "2"], "(", "y", ")"}], " ", "=", " ", "1"}], 
   TraditionalForm]],ExpressionUUID->"b314d47b-c81d-4cfc-bba5-9d75778a4618"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["f", "1"], "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["f", "2"], "(", "x", ")"}], "=", " ", 
     RowBox[{
      RowBox[{
       SubscriptBox["g", "1"], "(", "y", ")"}], " ", "=", " ", "0"}]}]}], 
   TraditionalForm]],ExpressionUUID->"ab5e3146-8ae1-486b-b15b-339df5e987f2"],
 "."
}], "Section",
 CellChangeTimes->{{3.858005431946518*^9, 3.858005432557581*^9}, {
  3.858005514128683*^9, 3.858005588003401*^9}, {3.858005684717749*^9, 
  3.858005685362142*^9}},ExpressionUUID->"e0442e2d-a2b8-4d21-9548-\
9f829085fd6a"],

Cell[TextData[{
 "u(x,y) = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"n", "=", "1"}], "\[Infinity]"], 
    RowBox[{
     RowBox[{"Sin", "[", "n\[Pi]y", "]"}], " ", 
     RowBox[{"Sinh", "[", "n\[Pi]x", "]"}], " ", "*", " ", 
     RowBox[{"{", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"-", "2"}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], "n"]}], 
        RowBox[{
         RowBox[{"Sinh", "(", "n\[Pi]", ")"}], " ", "*", " ", "n\[Pi]"}]], 
       "+", 
       FractionBox["1", 
        RowBox[{"n", "*", "\[Pi]", "*", 
         RowBox[{"Sinh", "(", "n\[Pi]", ")"}]}]]}], "}"}]}]}], 
   TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "24f66559-2712-4f75-ba44-656922365c52"],
 ". Again, evaluate only one term for brevity. \n\[Rule]u(x,y) = Sin[\[Pi] y] \
Sinh[\[Pi] x] ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     FractionBox["2", 
      RowBox[{
       RowBox[{"Sinh", "[", "\[Pi]", "]"}], "*", "\[Pi]"}]], "+", 
     FractionBox["1", 
      RowBox[{"\[Pi]", "*", 
       RowBox[{"Sinh", "[", "\[Pi]", "]"}]}]]}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "83a34ea5-f094-43cd-b47e-f6dc1dd0ba6d"],
 "}"
}], "Text",
 CellChangeTimes->{{3.858007586741227*^9, 3.858007590183032*^9}, {
  3.8580076961086397`*^9, 3.858007831687789*^9}, {3.858007911207891*^9, 
  3.858008145802744*^9}},ExpressionUUID->"9357a671-9849-471b-b56e-\
a78ccfec4eb5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Ben", " ", "=", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["u", "5"], "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", " ", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", "*", "y"}], "]"}], " ", "*", " ", 
     RowBox[{"Sinh", "[", 
      RowBox[{"\[Pi]", "*", "x"}], "]"}], "*", " ", 
     RowBox[{"(", 
      FractionBox["3", 
       RowBox[{"\[Pi]", "*", 
        RowBox[{"Sinh", "[", "\[Pi]", "]"}]}]], ")"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.858008171984702*^9, 3.8580082591217127`*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"b57e8c5d-b4a4-4bbc-8e6b-54ae2e6518a0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{"Ben", ",", 
   RowBox[{"{", 
